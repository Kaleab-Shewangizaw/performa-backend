NODE_ENV=development
PORT=3000

# PostgreSQL connection string (server runs PostgreSQL 10)
DATABASE_URL=postgres://performa:performa_dev_pw@localhost:5434/performa

# JWT secrets - generate your own with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=change_me
JWT_REFRESH_SECRET=change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=10
